# Server
PORT=3001
JWT_SECRET=change_this_to_a_random_secret_string

# MongoDB (Railway provides MONGO_URL automatically)
MONGO_URL=mongodb://localhost:27017/tollsync

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...         # Default price ID (overridden by admin panel)

# Admin (email of the admin user — bypasses subscription gate)
ADMIN_EMAIL=your@email.com

# Gmail Integration (Google Cloud OAuth2)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://your-app.railway.app/api/integrations/gmail/callback
CLIENT_URL=https://your-app.railway.app
